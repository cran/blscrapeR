Package: blscrapeR
Type: Package
Title: An API Wrapper for the United States Bureau of Labor Statistics
Version: 4.0.3
Encoding: UTF-8
Authors@R: person("Kris", "Eberwein", email = "kris.eberwein@gmail.com",
